<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_header"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_on_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_info"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="@string/btn_info"
            android:textSize="18sp"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/btn_header"
            android:focusable="true"
            android:nextFocusDown="@+id/status_card" />
    </LinearLayout>

    <!-- Full ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Status Card -->
            <LinearLayout
                android:id="@+id/status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg_focusable"
                android:padding="12dp"
                android:layout_marginBottom="6dp"
                android:focusable="true"
                android:clickable="true"
                android:nextFocusUp="@id/btn_info"
                android:nextFocusDown="@+id/btn_install_apk">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Install APK Button Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginBottom="6dp">

                <Button
                    android:id="@+id/btn_install_apk"
                    style="@style/BtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_install_apk"
                    android:nextFocusUp="@id/status_card"
                    android:nextFocusDown="@+id/btn_mdm_toggle" />
            </LinearLayout>

            <!-- Verizon MDM card -->
            <LinearLayout
                android:id="@+id/mdm_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_mdm_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_mdm_toggle"
                    style="@style/BtnOutline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nextFocusUp="@id/btn_install_apk"
                    android:nextFocusDown="@+id/searchBox" />
            </LinearLayout>

            <!-- Blacklist Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/blacklist_title"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/searchBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/search_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:minHeight="36dp"
                    android:nextFocusUp="@id/btn_install_apk"
                    android:nextFocusDown="@+id/filter_user" />

                <!-- Filter buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp">

                    <Button
                        android:id="@+id/filter_user"
                        style="@style/BtnCompact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginRight="3dp"
                        android:text="@string/filter_user"
                        android:nextFocusUp="@id/searchBox"
                        android:nextFocusRight="@+id/filter_system"
                        android:nextFocusDown="@+id/app_list_container" />

                    <Button
                        android:id="@+id/filter_system"
                        style="@style/BtnCompact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="3dp"
                        android:layout_marginRight="3dp"
                        android:text="@string/filter_system"
                        android:nextFocusUp="@id/searchBox"
                        android:nextFocusLeft="@id/filter_user"
                        android:nextFocusRight="@+id/filter_all"
                        android:nextFocusDown="@id/app_list_container" />

                    <Button
                        android:id="@+id/filter_all"
                        style="@style/BtnCompact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="3dp"
                        android:text="@string/filter_all"
                        android:nextFocusUp="@id/searchBox"
                        android:nextFocusLeft="@id/filter_system"
                        android:nextFocusDown="@id/app_list_container" />
                </LinearLayout>

                <!-- App list (dynamically populated) -->
                <LinearLayout
                    android:id="@+id/app_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/apps_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/apps_loading"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:padding="12dp"
                    android:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
